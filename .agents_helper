#!/bin/bash

# Agent Stack Helper Functions
# Source this file in your shell: source .agents_helper

# Quick agent commands overview
agents() {
    echo "🤖 Agent Stack Commands:"
    echo "npm run agent:memory:check        # Cross-session project memory"
    echo "npm run agent:plan               # Interactive planning assistant"
    echo "npm run agent:review             # Run all review lanes"
    echo "npm run agent:review:ci          # CI mode (non-interactive)"
    echo "npm run agent:security           # Interactive security scan"
    echo "npm run agent:security:ci        # CI mode security scan"
    echo "npm run agent:ui-review          # Frontend design review"
    echo "npm run agent:orchestrate        # CEO/EM/QA/Release coordination"
    echo "npm run agent:suppressions:validate   # Validate all suppressions"
    echo ""
    echo "📖 For full guide: agents-view"
}

# View full guide
agents-view() {
    if command -v code >/dev/null 2>&1; then
        code AGENT_STACK.md
    elif command -v vim >/dev/null 2>&1; then
        vim AGENT_STACK.md
    else
        cat AGENT_STACK.md
    fi
}

# Quick preview
agents-quick() {
    head -50 AGENT_STACK.md
}

# Browser view (if supported)
agents-browser() {
    open AGENT_STACK.md
}

# Health check all agents
agents-health() {
    echo "🏥 Running agent health checks..."
    npm run agent:memory:check && \
    npm run agent:review:ci && \
    npm run agent:security:ci && \
    npm run agent:suppressions:validate
}

echo "✅ Agent helper functions loaded. Type 'agents' for quick commands."